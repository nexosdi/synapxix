{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@nexosdi.synapxix/game-engine/core": [
        "libs/game-engine/core/src/index.ts"
      ],
      "@nexosdi.synapxix/auth0-config": ["auth0.config.ts"],
      "@nexosdi.synapxix/learning/shared": [
        "libs/learning/shared/src/index.ts"
      ],
      "@nexosdi.synapxix/prisma": ["libs/prisma/src/index.ts"],
      "@nexosdi.synapxix/baseRepository": ["libs/baseRepository/src/index.ts"],
      "@nexosdi.synapxix/envValidator": ["libs/envValidator/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
