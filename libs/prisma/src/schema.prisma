generator client {
    provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL") 
  schemas  = ["audit", "auth", "communication", "core", "knowledge", "psychometrics"]
}
model Institution {
  institution_id String @id @default(uuid()) @db.Uuid
  name           String?     @db.VarChar(150)
  description    String?
  created_at     DateTime    @default(now())
  structures     Structure[]

  @@map("institution")
  @@schema("core")
}

model Structure {
  structure_id   String @id @default(uuid()) @db.Uuid
  institution_id String @db.Uuid
  name           String          @db.VarChar(150)
  parent_id      String?         @db.Uuid
  description    String?
  created_at     DateTime        @default(now())
  userStructures UserStructure[]
  institution    Institution     @relation(fields: [institution_id], references: [institution_id])
  parent         Structure?      @relation("StructureToParent", fields: [parent_id], references: [structure_id])
  children       Structure[]     @relation("StructureToParent")

  @@map("structure")
  @@schema("core")
}

model app_user {
  user_id           String                  @id @default(uuid()) @db.Uuid
  username          String                  @db.VarChar(150)
  email             String                  @db.VarChar(150)
  firstname         String                  @db.VarChar(150)
  lastname          String                  @db.VarChar(150)
  role              String                  @default("user") @db.VarChar(150)
  created_at        DateTime                @default(now())
  active            Boolean                 @default(true)
  auditLogs         AuditLog[]
  sessions          Session[]
  linksFrom         UserLink[]              @relation("UserLinkFrom")
  linksTo           UserLink[]              @relation("UserLinkTo")
  userStructures    UserStructure[]
  notifications     Notification[]
  contentProgress   UserContentProgress[]
  credits           Int                     @default(0)
  transactions      EconomyTransaction[]    @relation("UserToTransactions")
  gameSessions      GameSession[]           @relation("UserToGameSessions")
  userProfile       UserProfile?

  @@map("app_user")
  @@schema("auth")
}

model EconomyTransaction{
  transaction_id    String @id @default(uuid()) @db.Uuid
  user_id String @db.Uuid
  game_session_id String @unique @db.VarChar(150)
  amount Int
  type String @default("GAME_VICTORY") @db.VarChar(50)
  created_at DateTime @default(now())

  user app_user @relation("UserToTransactions", fields: [user_id], references: [user_id])

  @@map ("economy_transaction")
  @@schema("core")
}

model UserLink {
  link_id      String @id @default(uuid()) @db.Uuid
  id_user_from String? @db.Uuid
  id_user_to   String? @db.Uuid
  link_type    linkType
  created_at   DateTime  @default(now())
  userFrom     app_user? @relation("UserLinkFrom", fields: [id_user_from], references: [user_id])
  userTo       app_user? @relation("UserLinkTo", fields: [id_user_to], references: [user_id])

  @@unique([id_user_from, id_user_to, link_type])
  @@map("user_link")
  @@schema("auth")
}

model UserStructure {
  user_id      String @db.Uuid
  structure_id String @db.Uuid
  structure    Structure @relation(fields: [structure_id], references: [structure_id])
  user         app_user  @relation(fields: [user_id], references: [user_id])

  @@id([user_id, structure_id])
  @@map("user_structure")
  @@schema("auth")
}

model Session {
  session_id String @id @default(uuid()) @db.Uuid
  user_id    String? @db.Uuid
  token      String
  created_at DateTime  @default(now())
  expires_at DateTime
  user       app_user? @relation(fields: [user_id], references: [user_id])

  @@map("session")
  @@schema("auth")
}

model Dimension {
  dimension_id String @id @default(uuid()) @db.Uuid
  name         String      @db.VarChar(150)
  description  String?
  archetypes   Archetype[] @relation("ArchetypeToDimension")
  
  @@map("dimension")
  @@schema("psychometrics")
}

model Archetype {
  archetype_id String                     @id @default(uuid()) @db.Uuid
  dimension_id String?  @db.Uuid
  name         String                  @db.VarChar(150)
  description  String?
  dimension    Dimension?              @relation("ArchetypeToDimension", fields: [dimension_id], references: [dimension_id])

  @@map("archetype")
  @@schema("psychometrics")
}



model Content {
  content_id      String @id @default(uuid()) @db.Uuid
  title           String
  description     String?
  prerequisite_id String? @db.Uuid
  created_at      DateTime              @default(now())
  prerequisite    Content?              @relation("ContentPrerequisite", fields: [prerequisite_id], references: [content_id])
  prerequisites   Content[]             @relation("ContentPrerequisite")
  userProgress    UserContentProgress[]

  @@map("content")
  @@schema("knowledge")
}

model UserContentProgress {
  user_id     String @db.Uuid
  content_id  String @db.Uuid
  completed   Boolean  @default(false)
  progress    Float?
  last_update DateTime @default(now())
  content     Content  @relation(fields: [content_id], references: [content_id])
  user        app_user @relation(fields: [user_id], references: [user_id])

  @@id([user_id, content_id])
  @@map("user_content_progress")
  @@schema("knowledge")
}

model AuditLog {
  audit_id   String @id @default(uuid()) @db.Uuid
  user_id    String?  @db.Uuid
  table_name String    @db.VarChar(100)
  record_id  String?   @db.Uuid
  timestamp  DateTime  @default(now())
  details    Json?
  user       app_user? @relation(fields: [user_id], references: [user_id])

  @@map("audit_log")
  @@schema("audit")
}

model Notification {
  notification_id String @id @default(uuid()) @db.Uuid
  user_id         String?  @db.Uuid
  title           String    @db.VarChar(150)
  message         String?
  read            Boolean   @default(false)
  created_at      DateTime  @default(now())
  user            app_user? @relation(fields: [user_id], references: [user_id])

  @@map("notification")
  @@schema("communication")
}

enum linkType {
  STUDENT  @map("1")
  ASSISTANT @map("2")
  TEACHER @map("3")
  DIRECTOR @map("4")

  @@schema("auth")
}

model GameSession {
  session_id        String    @id @default(uuid()) @db.Uuid
  user_id           String?   @db.Uuid
  history_id        String    @db.VarChar(150)
  status            String    @default("playing") @db.VarChar(20)
  category          String?   @db.VarChar(50)
  started_at        DateTime  @default(now())
  finished_at       DateTime?
  
  user              app_user? @relation("UserToGameSessions", fields: [user_id], references: [user_id])
  attempts          GameAttempt[]

  @@map("game_session")
  @@schema("core")
}

model GameAttempt {
  attempt_id        String      @id @default(uuid()) @db.Uuid
  session_id        String      @db.Uuid
  content_id        String      @db.VarChar(150)
  game_type         String      @db.VarChar(50)
  is_correct        Boolean
  score             Int
  completed_quickly Boolean?
  created_at        DateTime    @default(now())

  session           GameSession @relation(fields: [session_id], references: [session_id])

  @@map("game_attempt")
  @@schema("core")
}

model UserProfile {
  id            String    @id @default(uuid()) @db.Uuid
  theme         String    @default("dark") @db.VarChar(20)
  language      String    @default("es") @db.VarChar(10)
  notifications Boolean   @default(true)
  userId        String    @unique @map("user_id") @db.Uuid
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          app_user  @relation(fields: [userId], references: [user_id], onDelete: Cascade)

  @@map("user_profile")
  @@schema("auth")
}
