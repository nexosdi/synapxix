generator client {
  provider = "prisma-client"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["audit", "auth", "communication", "core", "knowledge", "psychometrics"]
}

model Institution {
  institution_id Int         @id @default(autoincrement())
  name           String?     @db.VarChar(150)
  description    String?
  created_at     DateTime    @default(now())
  structures     Structure[]

  @@map("institution")
  @@schema("core")
}

model Structure {
  structure_id   Int             @id @default(autoincrement())
  institution_id Int
  name           String          @db.VarChar(150)
  parent_id      Int?
  description    String?
  created_at     DateTime        @default(now())
  userStructures UserStructure[]
  institution    Institution     @relation(fields: [institution_id], references: [institution_id])
  parent         Structure?      @relation("StructureToParent", fields: [parent_id], references: [structure_id])
  children       Structure[]     @relation("StructureToParent")

  @@map("structure")
  @@schema("core")
}

model app_user {
  user_id           Int                     @id @default(autoincrement())
  username          String                  @db.VarChar(150)
  email             String                  @db.VarChar(150)
  password_hash     String
  firstname         String                  @db.VarChar(150)
  lastname          String                  @db.VarChar(150)
  role              String                  @default("user") @db.VarChar(150)
  created_at        DateTime                @default(now())
  active            Boolean                 @default(true)
  auditLogs         AuditLog[]
  sessions          Session[]
  linksFrom         UserLink[]              @relation("UserLinkFrom")
  linksTo           UserLink[]              @relation("UserLinkTo")
  userStructures    UserStructure[]
  notifications     Notification[]
  contentProgress   UserContentProgress[]
  archetypeProgress UserArchetypeProgress[]

  @@map("app_user")
  @@schema("auth")
}

enum Role {
  Manager
  Teacher
  Tutor
  Student  

@@schema("auth")
}

model UserLink {
  link_id      Int       @id @default(autoincrement())
  id_user_from Int?
  id_user_to   Int?
  link_type    Role   
  created_at   DateTime  @default(now())
  userFrom     app_user? @relation("UserLinkFrom", fields: [id_user_from], references: [user_id])
  userTo       app_user? @relation("UserLinkTo", fields: [id_user_to], references: [user_id])

  @@unique([id_user_from, id_user_to, link_type])
  @@map("user_link")
  @@schema("auth")
}

model UserStructure {
  user_id      Int
  structure_id Int
  structure    Structure @relation(fields: [structure_id], references: [structure_id])
  user         app_user  @relation(fields: [user_id], references: [user_id])

  @@id([user_id, structure_id])
  @@map("user_structure")
  @@schema("auth")
}

model Session {
  session_id Int       @id @default(autoincrement())
  user_id    Int?
  token      String
  created_at DateTime  @default(now())
  expires_at DateTime
  user       app_user? @relation(fields: [user_id], references: [user_id])

  @@map("session")
  @@schema("auth")
}

model Dimension {
  dimension_id Int         @id @default(autoincrement())
  name         String      @db.VarChar(150)
  description  String?
  archetypes   Archetype[] @relation("ArchetypeToDimension")

  @@map("dimension")
  @@schema("psychometrics")
}

model Archetype {
  archetype_id Int                     @id @default(autoincrement())
  dimension_id Int?
  name         String                  @db.VarChar(150)
  description  String?
  dimension    Dimension?              @relation("ArchetypeToDimension", fields: [dimension_id], references: [dimension_id])
  userProgress UserArchetypeProgress[]

  @@map("archetype")
  @@schema("psychometrics")
}

model UserArchetypeProgress {
  progress_id  Int        @id @default(autoincrement())
  user_id      Int?
  archetype_id Int?
  score        Float?     @default(0)
  last_update  DateTime   @default(now())
  archetype    Archetype? @relation(fields: [archetype_id], references: [archetype_id])
  user         app_user?  @relation(fields: [user_id], references: [user_id])

  @@unique([user_id, archetype_id])
  @@map("user_archetype_progress")
  @@schema("psychometrics")
}

model Content {
  content_id      Int                   @id @default(autoincrement())
  title           String
  description     String?
  prerequisite_id Int?
  created_at      DateTime              @default(now())
  prerequisite    Content?              @relation("ContentPrerequisite", fields: [prerequisite_id], references: [content_id])
  prerequisites   Content[]             @relation("ContentPrerequisite")
  userProgress    UserContentProgress[]

  @@map("content")
  @@schema("knowledge")
}

model UserContentProgress {
  user_id     Int
  content_id  Int
  completed   Boolean  @default(false)
  progress    Float?
  last_update DateTime @default(now())
  content     Content  @relation(fields: [content_id], references: [content_id])
  user        app_user @relation(fields: [user_id], references: [user_id])

  @@id([user_id, content_id])
  @@map("user_content_progress")
  @@schema("knowledge")
}

model AuditLog {
  audit_id   Int       @id @default(autoincrement())
  user_id    Int?
  table_name String    @db.VarChar(100)
  record_id  Int?
  timestamp  DateTime  @default(now())
  details    Json?
  user       app_user? @relation(fields: [user_id], references: [user_id])

  @@map("audit_log")
  @@schema("audit")
}

model Notification {
  notification_id Int       @id @default(autoincrement())
  user_id         Int?
  title           String    @db.VarChar(150)
  message         String?
  read            Boolean   @default(false)
  created_at      DateTime  @default(now())
  user            app_user? @relation(fields: [user_id], references: [user_id])

  @@map("notification")
  @@schema("communication")
}
