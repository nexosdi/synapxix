# Local environment overrides for Nx workspace.
# Node 22.12.0+ already provides crypto.hash, so no extra NODE_OPTIONS needed.

# Database
DATABASE_URL="postgresql://keycloak:secret123@localhost:5432/keycloakdb?schema=admin"

# Backend
PORT=3000
NODE_ENV=development

# Keycloak - Backend
KEYCLOAK_AUTH_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=prueba
KEYCLOAK_CLIENT_ID=testadmin-client
KEYCLOAK_SECRET=testadmin-secret
KEYCLOAK_ISSUER=http://localhost:8080/realms/prueba
KEYCLOAK_AUDIENCE=testadmin-client

# CORS
FRONTEND_URL=http://localhost:4200
