# ==============================================
# DATABASE CONFIGURATION
# ==============================================
# PostgreSQL Database URL para Prisma
# ==============================================
# POSTGRES - KEYCLOAK CONTAINER
# ==============================================
KEYCLOAK_DB_NAME="keycloakdb"
KEYCLOAK_DB_USER="keycloak"
KEYCLOAK_DB_PASSWORD="secret123"

# ==============================================
# POSTGRES - APP CONTAINER
# ==============================================
APP_DB_NAME="synapxix_db"
APP_DB_USER="synapxix"
APP_DB_PASSWORD="secret123"
APP_DB_PORT=5433

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
# PostgreSQL Database URL para Prisma (App DB)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://${APP_DB_USER}:${APP_DB_PASSWORD}@localhost:${APP_DB_PORT}/${APP_DB_NAME}"

# ==============================================
# NEO4J CONFIGURATION (Learning Module)
# ==============================================
NEO4J_URI="neo4j://localhost:7687"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="neo4j"

# ==============================================
# KEYCLOAK CONFIGURATION
# ==============================================
# Keycloak Server URL
KEYCLOAK_URL="http://localhost:8080"
KEYCLOAK_REALM="prueba"
KEYCLOAK_CLIENT_ID="angular-client"
KEYCLOAK_CLIENT_SECRET=""

# Keycloak Admin Credentials (para configuración inicial)
KEYCLOAK_ADMIN="admin"
KEYCLOAK_ADMIN_PASSWORD="admin"

# ==============================================
# BACKEND CONFIGURATION
# ==============================================
# Puerto del backend (admin-backend)
PORT=3000

# URL del frontend para CORS
FRONTEND_URL="http://localhost:4200"

# ==============================================
# FRONTEND CONFIGURATION
# ==============================================
# Puerto del frontend (admin-frontend)
# FRONTEND_PORT=4200

# ==============================================
# JWT CONFIGURATION
# ==============================================
# JWT Secret (genera uno seguro en producción)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRATION="1h"

# ==============================================
# NODE ENVIRONMENT
# ==============================================
NODE_ENV="development"
