# ─── Application Database (required) ────────────────────────────────────────
# PostgreSQL credentials for the app database.
# Must match the values in docker-compose.yml (or your external DB).
APP_DB_NAME=synapxix
APP_DB_USER=synapxix_user
APP_DB_PASSWORD=changeme
APP_DB_PORT=5434

# ─── Prisma (required) ────────────────────────────────────────────────────────
# Full connection string used by Prisma. Must match APP_DB_* above.
DATABASE_URL=postgresql://synapxix_user:changeme@localhost:5434/synapxix

# ─── Google Generative AI (required for AI features) ─────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_GEN_AI_KEY=your_google_ai_key_here

# ─── AI Retry Configuration (optional) ───────────────────────────────────────
# Controls the retry behaviour of the AiProvider when Gemini returns transient
# errors (HTTP 429, 500, 503). Safe to leave unset — sensible defaults apply.
AI_MAX_RETRIES=3
AI_RETRY_BASE_DELAY_MS=1000

# ─── Keycloak DB (only needed if running with --profile keycloak) ─────────────
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak_user
KEYCLOAK_DB_PASSWORD=changeme
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme

# ─── Neo4j (only needed if running with --profile neo4j) ─────────────────────
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme
